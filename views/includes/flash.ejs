 
 <!-- as success is an array which exists always but length=0  -->
 <%if(success && success.length){%>
 
 <div class="alert alert-success alert-dismissible fade show col-6 offset-3" role="alert">
    <!--success variable defined in res.locals in app.js -->
    <%=success%>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="close"></button>
</div>
<% } %>


 <%if(error && error.length){%>
 
 <div class="alert alert-danger alert-dismissible fade show col-6 offset-3" role="alert">
    <!--error variable defined in res.locals in app.js -->
    <%=error%>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="close"></button>
</div>
<% } %>